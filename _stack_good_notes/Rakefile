# -*- coding: utf-8 -*-
require "colorize"
require 'command_line/global'

$year = '2026'
$lecture = 'compa'
$local_dir = File.join('~/Sites/new_ist/Lectures',$year)
$lec_dir = File.expand_path(File.join($local_dir,$lecture))

task :default do
  system "rake -T"
end

desc "DIR : remove image DIR in local web site"
task :rm_image_dir => :show_dirs do 
  p comm = "rm -rf #{File.join($lec_dir, $source_dir)}"
  system comm
  exit
end

desc "show necessary dirs for display light table DIR public." #desc -> description
task :show_dirs do # any name on task_name
  if ARGV[1] == nil
    $source_dir = File.basename(Dir.pwd)
  else
    $source_dir = ARGV[1]
  end
  $source_yaml = $source_dir + ".yaml"
  $source_html = $source_dir + ".html"
  
  puts "Setup following dirs:".blue
  puts "#{$lec_dir}".blue
  puts "#{$ist_dir}".blue
  puts ""
end

desc "DIR : make DIR light table" #desc -> description
task :mk_light_table => :show_dirs do # any name on task_name
  $source_yaml = $source_dir + ".yaml"
  p comm = "hc mk_light_table -d #{$source_dir}"
  system comm
  puts "\nFor making light table structured, modify #{$source_yaml}.".green
  puts "hc mk_light_table -g #{$source_yaml}".green
  exit
end

desc "DIR : commit local DIR" #desc -> description
task :commit => :show_dirs do # any name on task_name
  ["mkdir #{File.join($lec_dir, $source_dir)}",
   "cp -rf #{$source_dir} #{$lec_dir}",
   "cp style.css #{$lec_dir}",
   "cp #{$source_html} #{$lec_dir}",
   "chmod -R a+r #{$lec_dir}"
   ].each do |comm|
    p comm
    system comm
  end
  exit
end

desc "DIR : push DIR light tables to web server"
task :push => :show_dirs do
  $ist_dir = File.join("nishitani@ist.ksc.kwansei.ac.jp:~/public_html/Lectures",
                       $year)
  $https_dir = File.join("https://ist.ksc.kwansei.ac.jp/~nishitani/Lectures",
                         $year, $lecture, $source_html)
  ["rsync --exclude .git -auvz -e ssh ~/Sites/new_ist/ nishitani@ist.ksc.kwansei.ac.jp:~/public_html",
   "open #{$https_dir}"].each do |comm|
    puts comm
    system comm
  end
end
